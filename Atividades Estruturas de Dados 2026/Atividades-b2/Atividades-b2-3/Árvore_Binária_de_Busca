arvore = ArvoreBST()

valores = [50, 30, 70, 20, 40, 60, 80, 10, 35]

for valor in valores:
    arvore.inserir(valor)

# Diagnóstico específico
valor_busca = 30

# Diagnóstico geral
arvore.analisar_arvore(valor_busca)

# IDs de memória
arvore.imprimir_ids_memoria()
